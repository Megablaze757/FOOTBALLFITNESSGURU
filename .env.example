# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Rotate any credential that has ever been pasted into chat, a commit, or a log.

# --- Supabase ---
# Found in: Dashboard > Project Settings > API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side ONLY, never ship to client

# Direct Postgres connection (for running migrations locally).
# Reset this password in Dashboard > Project Settings > Database if it was ever exposed.
SUPABASE_DB_URL=postgresql://postgres:CHANGE_ME@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# --- AI microservice (Phase 2+) ---
AI_WORKER_URL=https://ai-worker.yourdomain.com
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Stripe (Phase 4) ---
# Set these as secrets on the Edge Functions: `supabase secrets set ...`
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=          # signing secret of the Stripe webhook endpoint
STRIPE_PRICE_SILVER=price_xxx   # Stripe recurring price ID for the Silver plan
STRIPE_PRICE_GOLD=price_xxx     # Stripe recurring price ID for the Gold plan
APP_URL=http://localhost:3000   # used for Stripe Checkout success/cancel redirects
