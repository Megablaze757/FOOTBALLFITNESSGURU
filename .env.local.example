# Copy to `.env.local` (gitignored) for the Next.js app.
# These are the dummy-project values; swap for the real project at migration time.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional — your Cloudflare Worker URL (AI via OpenRouter, Stripe, email).
# Leave blank to use the local engine / Supabase Edge Functions. See cloudflare/README.md.
NEXT_PUBLIC_API_URL=
